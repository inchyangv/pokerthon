PORT=8000
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/pokerthon
ADMIN_PASSWORD=changeme_admin_password
APP_ENCRYPTION_KEY=changeme_32_char_key_here_______
ACTION_TIMEOUT_SECONDS=600
TABLE_BUYIN=40
SMALL_BLIND=1
BIG_BLIND=2

# Tournament blind escalation
# Set to ISO datetime with timezone to enable automatic blind increases.
# Schedule: 1/2 → 2/4 (+48h) → 3/6 (+96h) → 4/8 (+144h)
# Leave unset (or remove) to disable auto escalation.
TOURNAMENT_START_AT=2026-04-02T00:00:00+09:00
BLIND_LEVEL_HOURS=48

# Bot settings
BOT_ENABLED=true
BOT_POLL_INTERVAL=2.0
BOT_ACTION_DELAY_MIN=1.0
BOT_ACTION_DELAY_MAX=3.0
BOT_AUTO_SEED=false
BOT_INITIAL_CHIPS=1000
